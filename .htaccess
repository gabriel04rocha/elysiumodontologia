# .htaccess para Next.js Static Export (cPanel/Apache)
# Configurado para trailingSlash: true

RewriteEngine On
RewriteBase /

# 1. Garante que se o usuário acessar /página (sem barra), ele seja levado para /página/
# Isso ajuda o Apache a encontrar o index.html dentro da pasta e evita erros de caminho do JS/CSS
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !index\.html
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^(.*)$ $1/ [L,R=301]

# 2. Configura o 404 personalizado do Next.js
ErrorDocument 404 /404.html

# 3. Impede a listagem de diretórios
Options -Indexes

# 4. Melhora cache para arquivos estáticos do Next.js (_next/static)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>
