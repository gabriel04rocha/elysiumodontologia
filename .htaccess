<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Permite acesso à pasta _next e outros arquivos estáticos
  # Isso garante que o CSS e JS carreguem corretamente
  RewriteCond %{REQUEST_URI} ^/_next/static/.*$ [OR]
  RewriteCond %{REQUEST_URI} ^/assets/.*$ [OR]
  RewriteCond %{REQUEST_URI} ^/Logos/.*$
  RewriteRule ^ - [L]

  # Mapeia URLs sem extensão para arquivos .html
  # Exemplo: dominio.com/contato -> dominio.com/contato.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L,QSA]

  # Força HTTPS se não estiver usando
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Cache headers para performance
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 year"
</IfModule>
