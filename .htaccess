<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Permite acesso total à pasta _next e outros ativos
  # O cPanel às vezes bloqueia pastas com underscore, isso força a permissão
  RewriteCond %{REQUEST_URI} ^/_next/.*$
  RewriteRule ^ - [L]

  # 2. Garante que imagens e logos sejam servidos sem passar pelas regras de roteamento
  RewriteCond %{REQUEST_URI} ^/Logos/.*$ [OR]
  RewriteCond %{REQUEST_URI} ^/favicon.ico$
  RewriteRule ^ - [L]

  # 3. Trata o roteamento de pastas para o Next.js (trailingSlash: true)
  # Se o usuário acessar dominio.com/contato, redireciona para dominio.com/contato/ com barra
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !index.html$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ $1/ [R=301,L]

  # Se o arquivo físico ou diretório não existir, tenta carregar o index.html da pasta correspondente
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ $1/index.html [L,QSA]

  # 4. Força HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Cache e Performance
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 year"
</IfModule>
